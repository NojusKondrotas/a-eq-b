{
  "name": "a-eq-b",
  "module": "src/index.ts",
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "copyfiles": "^2.4.1",
    "pug": "^3.0.4",
    "pug-cli": "^1.0.0-alpha6",
    "serve": "^14.2.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "build": "tsc && pug ./src --out ./dist --hierarchy && copyfiles -u 1 \"src/**/*.css\" dist",
