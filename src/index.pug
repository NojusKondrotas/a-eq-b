doctype html 
html(lang="en")
    head 
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        base(href="/")
        title a -eq b
        link(rel="stylesheet" href="/index.css")
        link(rel="stylesheet" href="/stylesheets/universal.css")
        link(rel="stylesheet" href="/stylesheets/utils.css")
    body 
        include pages/mixins/_index_mixins

        .width-full.justify-center
            #sorts-box 
                +sort_container('merge', '/pages/sorts/merge.html', 'merge sort')
                +sort_container('insertion', '/pages/sorts/insertion.html', 'insertion sort')
                +sort_container('selection', '/pages/sorts/selection.html', 'selection sort')
                +sort_container('quick', '/pages/sorts/quick.html', 'quicksort')
                +sort_container('bubble', '/pages/sorts/bubble.html', 'bubble sort')
                +sort_container('heap', '/pages/sorts/heap.html', 'heapsort')
        
        script(type="module" src="/index.js")