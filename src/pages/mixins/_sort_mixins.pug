mixin param_config(name, id, control, min, max, value)
    .configs.flex.flex-col.justify-center.items-center
        p.flex.justify-center.text-base= name
        if control 
            input.w-full(id=`${id}-input` type="range" min=`${min}` max=`${max}` value=`${value}`)
        p(id=`${id}-val`).flex.justify-center.text-base

mixin config(guide)
    #configurations
        +param_config(['min', 'freq'].join(' '), ['min', 'freq'].join('-'), 'y', '200', '2200', '200')
        +param_config(['max', 'freq'].join(' '), ['max', 'freq'].join('-'), 'y', '200', '2200', '500')
        +param_config('n', 'arr-size', 'y', '2', '200', '10')
        +param_config('bot comparison length', 'comparison-len', 'y', '1', '2000', '350')
        +param_config(['freq', 'diff'].join(' '), ['freq', 'diff'].join('-'))
        p#guide-text.relative.m-0.left-4.justify-self-start.self-start.text-base= guide
        #start-game
            button#start-game-btn.box start
    #keyboard(class="absolute w-full m-0 bottom-[45px] flex justify-center items-center select-none" style="display: none;")
        img#keyboard(class="w-7/10 h-[428px] object-contain" draggable="false" src="res/ABCDEF_ibm_kb.png")